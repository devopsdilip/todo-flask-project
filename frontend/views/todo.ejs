<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo Page</title>
</head>
<body>

    <h1>Todo Form</h1>

    <form action="/submit" method="POST">

        <label for="itemId">Item ID</label><br>
        <input
            type="text"
            id="itemId"
            name="itemId"
            required
        >
        <br><br>

        <label for="itemUUID">Item UUID</label><br>
        <input
            type="text"
            id="itemUUID"
            name="itemUUID"
            required
        >
        <br><br>

        <label for="itemHash">Item Hash</label><br>
        <input
            type="text"
            id="itemHash"
            name="itemHash"
            required
        >
        <br><br>

        <label for="itemName">Item Name</label><br>
        <input
            type="text"
            id="itemName"
            name="itemName"
            required
        >
        <br><br>

        <label for="itemDescription">Item Description</label><br>
        <textarea
            id="itemDescription"
            name="itemDescription"
            rows="5"
            cols="40"
            required
        ></textarea>
        <br><br>

        <button type="submit">Submit</button>

    </form>

</body>
</html>
